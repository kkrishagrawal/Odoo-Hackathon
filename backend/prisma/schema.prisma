generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id           String   @id @db.Uuid
  name         String
  countryCode  String   @map("country_code") @db.Char(2)
  baseCurrency String   @map("base_currency") @db.Char(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  users User[]
  approvalRules ApprovalRule[]

  @@map("companies")
}

model User {
  id           String   @id @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  fullName     String   @map("full_name")
  email        String
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  approvalRules       ApprovalRule[]       @relation("ApprovalRuleTargetUser")
  managerRules        ApprovalRule[]       @relation("ApprovalRuleManagerUser")
  createdRules        ApprovalRule[]       @relation("ApprovalRuleCreatedBy")
  approverRules       ApprovalRuleApprover[] @relation("ApprovalRuleApproverUser")
  expenses            Expense[]

  @@index([companyId], map: "users_company_id_idx")
  @@map("users")
}

model ApprovalRule {
  id                     String   @id @db.Uuid
  companyId              String   @map("company_id") @db.Uuid
  targetUserId           String   @map("target_user_id") @db.Uuid
  managerUserId          String?  @map("manager_user_id") @db.Uuid
  createdByUserId        String   @map("created_by_user_id") @db.Uuid
  description            String?
  includeManagerApprover Boolean  @default(true) @map("include_manager_approver")
  requireSequential      Boolean  @default(false) @map("require_sequential")
  minimumApprovalPercent Int      @default(100) @map("minimum_approval_percent")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  company       Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  targetUser    User                   @relation("ApprovalRuleTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  managerUser   User?                  @relation("ApprovalRuleManagerUser", fields: [managerUserId], references: [id], onDelete: SetNull)
  createdByUser User                   @relation("ApprovalRuleCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  approvers     ApprovalRuleApprover[]

  @@index([companyId], map: "approval_rules_company_id_idx")
  @@index([targetUserId], map: "approval_rules_target_user_id_idx")
  @@index([managerUserId], map: "approval_rules_manager_user_id_idx")
  @@unique([companyId, targetUserId], map: "approval_rules_company_target_user_unique_idx")
  @@map("approval_rules")
}

model ApprovalRuleApprover {
  id             String   @id @db.Uuid
  approvalRuleId String   @map("approval_rule_id") @db.Uuid
  approverUserId String   @map("approver_user_id") @db.Uuid
  isRequired     Boolean  @default(false) @map("is_required")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  approvalRule ApprovalRule @relation(fields: [approvalRuleId], references: [id], onDelete: Cascade)
  approverUser User         @relation("ApprovalRuleApproverUser", fields: [approverUserId], references: [id], onDelete: Cascade)

  @@index([approvalRuleId], map: "approval_rule_approvers_rule_id_idx")
  @@index([approverUserId], map: "approval_rule_approvers_approver_user_id_idx")
  @@unique([approvalRuleId, approverUserId], map: "approval_rule_approvers_rule_approver_unique_idx")
  @@map("approval_rule_approvers")
}

model RefreshToken {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "refresh_tokens_user_id_idx")
  @@index([tokenHash], map: "refresh_tokens_token_hash_idx")
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash], map: "password_reset_tokens_token_hash_idx")
  @@map("password_reset_tokens")
}

model Expense {
  id          String   @id @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  description String
  expenseDate String   @map("expense_date")
  category    String
  paidBy      String   @default("") @map("paid_by")
  remarks     String   @default("")
  amount      Float
  currency    String   @db.Char(3)
  status      String   @default("Draft")
  receiptUrl  String   @default("") @map("receipt_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "expenses_user_id_idx")
  @@index([status], map: "expenses_status_idx")
  @@map("expenses")
}
